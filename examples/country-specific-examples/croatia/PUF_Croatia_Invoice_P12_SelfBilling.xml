<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<Invoice xmlns:cac="urn:pagero:CommonAggregateComponents:1.0" xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2" xmlns:puf="urn:pagero:ExtensionComponent:1.0" xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2" xmlns="urn:pagero:PageroUniversalFormat:Invoice:1.0">

    <!-- Values in invoice are examples values only. -->
    <!-- Self-billing: the buyer (Kupac Split d.o.o.) issues this invoice on behalf of the seller (Dobavljač Rijeka d.o.o.) -->

    <ext:UBLExtensions>
        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:SelfBilled</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <puf:SelfBilled>true</puf:SelfBilled>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
    </ext:UBLExtensions>

    <cbc:CustomizationID>urn:pagero.com:puf:billing:2.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:pagero.com:puf:billing:1.0</cbc:ProfileID>
    <!-- BT-1 Invoice Number -->
    <cbc:ID>SB-2025-00042</cbc:ID>
    <!-- BT-2 Invoice Issue Date  -->
    <cbc:IssueDate>2025-03-15</cbc:IssueDate>
    <!-- HR-BT-2 Issue time (mandatory in Croatia) -->
    <cbc:IssueTime>10:15:00</cbc:IssueTime>
    <!-- BT-9 Due Date -->
    <cbc:DueDate>2025-04-15</cbc:DueDate>
    <!-- BT-3 Invoice Type Code: 380 = Invoice with P12 = Self-billing process, self-billing indicated via puf:SelfBilled extension -->
    <cbc:InvoiceTypeCode name="P12">380</cbc:InvoiceTypeCode>
    <!-- BT-5 Invoice Document Currency (Croatia uses EUR) -->
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
    <!-- BG-4 Seller (the party being billed on behalf of) -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <!-- BT-34 Seller endpoint ID with Croatian OIB -->
            <cbc:EndpointID schemeID="9934">22334455667</cbc:EndpointID>
            <!-- BT-28 Seller Trading Name -->
            <cac:PartyName>
                <cbc:Name>Dobavljač Rijeka d.o.o.</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <!--BT-35 Seller address street-->
                <cbc:StreetName>Korzo 5</cbc:StreetName>
                <!-- BT-37 Seller address City -->
                <cbc:CityName>Rijeka</cbc:CityName>
                <!-- BT-38 Seller address postal code -->
                <cbc:PostalZone>51000</cbc:PostalZone>
                <cac:Country>
                    <!-- BT-40 Seller address country code -->
                    <cbc:IdentificationCode>HR</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <!-- BT-31 Seller Vat Number with Croatian HR prefix -->
                <cbc:CompanyID>HR22334455667</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <!-- BT-27 Seller Registration Name -->
                <cbc:RegistrationName>Dobavljač Rijeka d.o.o.</cbc:RegistrationName>
                <!--BT-33 Company Legal Form-->
                <cbc:CompanyLegalForm>d.o.o. osnovana na Trgovačkom sudu u Rijeci, temeljni kapital 20.000,00 EUR, direktor Ana Kovačić</cbc:CompanyLegalForm>
            </cac:PartyLegalEntity>
        </cac:Party>
        <!-- HR-BT-4 and HR-BT-5 Operator information (mandatory for Croatian fiscalization) -->
        <cac:SellerContact>
            <!-- HR-BT-5 Operator OIB -->
            <cbc:ID>99887766554</cbc:ID>
            <!-- HR-BT-4 Operator Name -->
            <cbc:Name>Operater Rijeka</cbc:Name>
        </cac:SellerContact>
    </cac:AccountingSupplierParty>
    <!-- BG-7 Buyer (the party issuing the self-billed invoice) -->
    <cac:AccountingCustomerParty>
        <cbc:SupplierAssignedAccountID>CRO-BUYER-001</cbc:SupplierAssignedAccountID>
        <cac:Party>
            <!-- BT-49 Buyer endpoint ID with Croatian OIB -->
            <cbc:EndpointID schemeID="9934">10987654321</cbc:EndpointID>
            <!-- BT-45 Buyer Trading Name -->
            <cac:PartyName>
                <cbc:Name>Kupac Split d.o.o.</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <!-- BT-50 Buyer address street-->
                <cbc:StreetName>Riva 12</cbc:StreetName>
                <!-- BT-52 Buyer address City -->
                <cbc:CityName>Split</cbc:CityName>
                <!-- BT-53 Buyer address postal code -->
                <cbc:PostalZone>21000</cbc:PostalZone>
                <cac:Country>
                    <!-- BT-55 Buyer address country code -->
                    <cbc:IdentificationCode>HR</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <!-- BT-48 Buyer Vat Number -->
                <cbc:CompanyID>HR10987654321</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <!-- BT-44 Buyer Name -->
                <cbc:RegistrationName>Kupac Split d.o.o.</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>
    <cac:Delivery>
        <!-- BT-72 Actual Delivery Date-->
        <cbc:ActualDeliveryDate>2025-03-10</cbc:ActualDeliveryDate>
    </cac:Delivery>
    <cac:PaymentMeans>
        <!-- BT-81 Payment means code. -->
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode>
        <!-- BT-83 Remittance information -->
        <cbc:PaymentID>HR7623400002233445566</cbc:PaymentID>
        <cac:PayeeFinancialAccount>
            <!-- BT-84 A unique identifier of the financial payment account -->
            <cbc:ID>HR1724020061100009876</cbc:ID>
            <cac:FinancialInstitutionBranch>
                <!-- BT-86 BIC -->
                <cbc:ID>HPBZHR2X</cbc:ID>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>
    <!-- BG-23 VAT breakdown -->
    <cac:TaxTotal>
        <!-- BT-110 Invoice total VAT amount -->
        <cbc:TaxAmount currencyID="EUR">125.00</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <!-- BT-116 Taxable amount -->
            <cbc:TaxableAmount currencyID="EUR">500.00</cbc:TaxableAmount>
            <!-- BT-117 Tax amount -->
            <cbc:TaxAmount currencyID="EUR">125.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <!-- BT-118 VAT category code -->
                <cbc:ID>S</cbc:ID>
                <!-- HR-BT-12 Croatian tax category label -->
                <cbc:Name>HR:PDV25</cbc:Name>
                <!-- BT-119 VAT category rate (Croatian standard rate 25%) -->
                <cbc:Percent>25.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>
    <!-- BG-22 Document totals -->
    <cac:LegalMonetaryTotal>
        <!-- BT-106 Sum of all Invoice line net amounts -->
        <cbc:LineExtensionAmount currencyID="EUR">500.00</cbc:LineExtensionAmount>
        <!-- BT-109 Invoice total amount without VAT -->
        <cbc:TaxExclusiveAmount currencyID="EUR">500.00</cbc:TaxExclusiveAmount>
        <!-- BT-112 Invoice total amount with VAT -->
        <cbc:TaxInclusiveAmount currencyID="EUR">625.00</cbc:TaxInclusiveAmount>
        <!-- BT-115 Amount due for payment -->
        <cbc:PayableAmount currencyID="EUR">625.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>
    <!-- BG-25 Invoice line -->
    <cac:InvoiceLine>
        <!-- BT-126 Line ID -->
        <cbc:ID>1</cbc:ID>
        <!-- BT-129 Invoiced Quantity -->
        <cbc:InvoicedQuantity unitCode="EA">10</cbc:InvoicedQuantity>
        <!-- BT-131 Line extension amount -->
        <cbc:LineExtensionAmount currencyID="EUR">500.00</cbc:LineExtensionAmount>
        <cac:Item>
            <!-- BT-153 Article/Item Description -->
            <cbc:Name>Sirovina za proizvodnju - čelične cijevi</cbc:Name>
            <!-- Croatian item classification (mandatory for Croatia) -->
            <cac:CommodityClassification>
                <cbc:ItemClassificationCode listID="CG">24.20.11</cbc:ItemClassificationCode>
            </cac:CommodityClassification>
            <cac:ClassifiedTaxCategory>
                <!-- BT-151 Invoiced item VAT category code -->
                <cbc:ID>S</cbc:ID>
                <!-- HR-BT-12 Croatian tax category label -->
                <cbc:Name>HR:PDV25</cbc:Name>
                <!-- BT-152 Invoiced item VAT rate -->
                <cbc:Percent>25</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <!-- BT-146 Item net price -->
            <cbc:PriceAmount currencyID="EUR">50.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>
</Invoice>
