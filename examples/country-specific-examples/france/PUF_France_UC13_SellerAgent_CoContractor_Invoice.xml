<?xml version="1.0" encoding="UTF-8"?>
<!--
    PUF Invoice Example: UC13 - SELLER AGENT Co-Contractor Invoice

    Use Case: Sales Invoice with Seller Agent (Platform/Marketplace Acting on Behalf of Seller)
    Country: France (EXTENDED-CTC-FR profile)
    Format: PUF (Pagero Universal Format) 2.0
    Document Type: Standard Commercial Invoice (Type 380)
    Business Process: S6 (Co-contractor services invoice)

    Scenario Description:
    A construction subcontractor (Bâtiment Solutions Provence SAS - "sous-traitant") provides
    co-contractor construction services to a general contractor (Groupe Construction Île-de-France SA -
    "entrepreneur principal"). A digital platform (PlateformeFacture Pro SARL - "agent du vendeur")
    acts as SELLER AGENT, managing invoice issuance and lifecycle on behalf of the subcontractor.

    Co-Contractor Model:
    - SELLER (Sous-traitant): Bâtiment Solutions Provence SAS - Construction subcontractor
    - SELLER AGENT (Plateforme): PlateformeFacture Pro SARL - Platform managing invoices for seller
    - BUYER (Entrepreneur principal): Groupe Construction Île-de-France SA - General contractor

    SELLER AGENT Responsibilities:
    1. Manages invoice creation and issuance on behalf of SELLER
    2. Handles document lifecycle on PA-TR platform
    3. Posts lifecycle statuses (deposit, validation, payment)
    4. Ensures regulatory compliance of invoice format
    5. Manages electronic archiving obligations

    Key Implementation: SELLER AGENT in cac:AccountingSupplierParty
    - SELLER AGENT placed within cac:AccountingSupplierParty/cac:Party/cac:AgentParty
    - Platform identified with role code "SR" (Seller's agent)
    - Provides complete party details: name, SIREN/SIRET, VAT, address

    Key Characteristics:
    - Invoice type 380: Standard commercial invoice
    - Business process S6: Co-contractor services invoice
    - BG-4 SELLER: Construction subcontractor (Bâtiment Solutions Provence SAS)
    - EXT-FR-FE-BG-03 SELLER AGENT: Platform (PlateformeFacture Pro SARL)
    - BG-7 BUYER: General contractor (Groupe Construction Île-de-France SA)
    - Total: 25,000.00 EUR

    Workflow:
    1. SELLER (subcontractor) performs co-contractor construction services
    2. SELLER AGENT (platform) creates and issues invoice on behalf of SELLER
    3. SELLER AGENT manages lifecycle statuses on PA-TR
    4. BUYER receives invoice and validates
    5. BUYER pays SELLER directly

    French Text Codes Used:
    - #REG# Registration information
    - #ABL# Trade register number (RCS)
    - #AAI# Additional info (co-contractor and seller agent explanation)
    - #PMD# Late payment penalties
    - #PMT# Fixed collection costs
    - #BAR# Treatment type (B2B)

    Date: 2026-03-01
    Reference: XP Z12-014 Annexe A, Section 3.2.12 - Cas n°13
-->
<Invoice xmlns="urn:pagero:PageroUniversalFormat:Invoice:1.0" xmlns:cac="urn:pagero:CommonAggregateComponents:1.0" xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:puf="urn:pagero:ExtensionComponent:1.0" xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2">

    <!-- UBL Version -->
    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>

    <!-- BT-24 Specification identifier -->
    <cbc:CustomizationID>urn:pagero.com:puf:billing:2.0</cbc:CustomizationID>
    <!-- BT-23 Business process type -->
    <cbc:ProfileID>urn:pagero.com:puf:billing:1.0</cbc:ProfileID>

    <!-- BT-1: Invoice number -->
    <cbc:ID>BSP-2026-COTR-0312</cbc:ID>

    <!-- BT-2: Invoice issue date -->
    <cbc:IssueDate>2026-03-01</cbc:IssueDate>

    <!-- BT-9: Payment due date (30 days) -->
    <cbc:DueDate>2026-03-31</cbc:DueDate>

    <!-- BT-3: Invoice type code = 380 (Standard commercial invoice)
         @name = S6 (Co-contractor services invoice) -->
    <cbc:InvoiceTypeCode name="S6">380</cbc:InvoiceTypeCode>

    <!-- BT-21/BT-22: Invoice notes with French text codes -->
    <!-- #REG#: Company legal form and share capital -->
    <cbc:Note>#REG#SAS au capital de 250 000 EUR</cbc:Note>
    <!-- #ABL#: Trade register number (RCS) -->
    <cbc:Note>#ABL#RCS Aix-en-Provence B 444 555 666</cbc:Note>
    <!-- #AAI#: Additional invoice information - co-contractor and seller agent explanation -->
    <cbc:Note>#AAI#FACTURE DE CO-TRAITANCE AVEC AGENT DU VENDEUR: Cette facture est émise dans le cadre d'un contrat de co-traitance pour le chantier de rénovation du Centre Commercial Les Terrasses de Provence. Le sous-traitant Bâtiment Solutions Provence SAS agit en qualité de co-traitant conformément à l'article 1er de la loi n°75-1334 du 31 décembre 1975. La gestion de la facturation et du cycle de vie du document est assurée par PlateformeFacture Pro SARL agissant en qualité d'agent du vendeur (code rôle SR) sur la plateforme PA-TR. L'agent du vendeur est mandaté pour émettre les factures, gérer les statuts de cycle de vie et assurer la conformité réglementaire pour le compte du co-traitant.</cbc:Note>
    <!-- #PMD#: Late payment penalties -->
    <cbc:Note>#PMD#En cas de retard de paiement, application des pénalités à un taux égal au taux d'intérêt appliqué par la BCE majoré de 10 points de pourcentage</cbc:Note>
    <!-- #PMT#: Fixed collection costs -->
    <cbc:Note>#PMT#Indemnité forfaitaire pour frais de recouvrement en cas de retard de paiement : 40 EUR</cbc:Note>
    <!-- #BAR#: Treatment type - B2B -->
    <cbc:Note>#BAR#B2B</cbc:Note>

    <!-- BT-5: Invoice currency code -->
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>

    <!-- BT-10: Buyer reference -->
    <cbc:BuyerReference>GCIF-REF-CHANTIER-2026-048</cbc:BuyerReference>

    <!-- BT-13: Purchase order reference -->
    <cac:OrderReference>
        <cbc:ID>GCIF-PO-COTR-2026-0048</cbc:ID>
    </cac:OrderReference>

    <!-- BT-12: Contract reference (Co-contractor agreement) -->
    <cac:ContractDocumentReference>
        <cbc:ID>CONTRAT-COTRAITANCE-2025-112</cbc:ID>
    </cac:ContractDocumentReference>

    <!-- BG-4: SELLER (Accounting Supplier Party) - Construction Subcontractor -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <!-- BT-34: Seller electronic address (SIRET) -->
            <cbc:EndpointID schemeID="0009">44455566600011</cbc:EndpointID>

            <!-- BT-29: SIRET identifier -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="0009">44455566600011</cbc:ID>
            </cac:PartyIdentification>

            <!-- BT-28: Seller trading name -->
            <cac:PartyName>
                <cbc:Name>Bâtiment Solutions Provence</cbc:Name>
            </cac:PartyName>

            <!-- BG-5: Seller postal address -->
            <cac:PostalAddress>
                <!-- BT-35: Seller address line 1 -->
                <cbc:StreetName>Zone Industrielle Les Milles, 18 Avenue Henri Malacrida</cbc:StreetName>
                <!-- BT-37: Seller city -->
                <cbc:CityName>Aix-en-Provence</cbc:CityName>
                <!-- BT-38: Seller post code -->
                <cbc:PostalZone>13290</cbc:PostalZone>
                <!-- BT-40: Seller country code -->
                <cac:Country>
                    <cbc:IdentificationCode>FR</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>

            <!-- BT-31: Seller VAT identifier -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>FR44444555666</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>

            <!-- BT-27: Seller legal name -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Bâtiment Solutions Provence SAS</cbc:RegistrationName>
                <!-- BT-30: Seller legal registration identifier (SIREN) -->
                <cbc:CompanyID schemeID="0002">444555666</cbc:CompanyID>
            </cac:PartyLegalEntity>

            <!-- BG-6: Seller contact -->
            <cac:Contact>
                <cbc:Name>Jean-Pierre Duval - Directeur Travaux</cbc:Name>
                <cbc:Telephone>+33 4 42 00 11 22</cbc:Telephone>
                <cbc:ElectronicMail>jp.duval@batiment-solutions-provence.fr</cbc:ElectronicMail>
            </cac:Contact>

            <!-- EXT-FR-FE-BG-03: SELLER AGENT (Agent du Vendeur) - Platform
                 Role Code "SR" = Seller's agent (UNTDID 3035)

                 The SELLER AGENT (PlateformeFacture Pro SARL) acts on behalf of the
                 SELLER (Bâtiment Solutions Provence SAS) to:
                 - Create and issue invoices on behalf of SELLER
                 - Manage document lifecycle on PA-TR platform
                 - Post lifecycle statuses (deposit, validation, payment)
                 - Ensure regulatory compliance
                 - Manage electronic archiving -->
            <cac:AgentParty>
                <!-- EXT-FR-FE-67: SELLER AGENT Role Code -->
                <ext:UBLExtensions>
                    <ext:UBLExtension>
                        <ext:ExtensionURI>
                                urn:pagero:ExtensionComponent:1.0:PageroExtension:PartyExtension</ext:ExtensionURI>
                        <ext:ExtensionContent>
                            <puf:PageroExtension>
                                <puf:PartyExtension>
                                    <puf:RoleCode>
                                        <cbc:ID>SR</cbc:ID>
                                    </puf:RoleCode>
                                </puf:PartyExtension>
                            </puf:PageroExtension>
                        </ext:ExtensionContent>
                    </ext:UBLExtension>
                </ext:UBLExtensions>

                <!-- SELLER AGENT Electronic Address -->
                <cbc:EndpointID schemeID="0009">77788899900011</cbc:EndpointID>

                <!-- SELLER AGENT Trading Name -->
                <cac:PartyName>
                    <cbc:Name>PlateformeFacture Pro</cbc:Name>
                </cac:PartyName>

                <!-- SELLER AGENT Postal Address -->
                <cac:PostalAddress>
                    <cbc:StreetName>42 Rue de la Technologie</cbc:StreetName>
                    <cbc:CityName>Marseille</cbc:CityName>
                    <cbc:PostalZone>13001</cbc:PostalZone>
                    <cac:Country>
                        <cbc:IdentificationCode>FR</cbc:IdentificationCode>
                    </cac:Country>
                </cac:PostalAddress>

                <!-- SELLER AGENT VAT Identifier -->
                <cac:PartyTaxScheme>
                    <cbc:CompanyID>FR77777888999</cbc:CompanyID>
                    <cac:TaxScheme>
                        <cbc:ID>VAT</cbc:ID>
                    </cac:TaxScheme>
                </cac:PartyTaxScheme>

                <!-- SELLER AGENT Legal Entity -->
                <cac:PartyLegalEntity>
                    <cbc:RegistrationName>PlateformeFacture Pro SARL</cbc:RegistrationName>
                    <!-- SELLER AGENT SIREN -->
                    <cbc:CompanyID schemeID="0002">777888999</cbc:CompanyID>
                </cac:PartyLegalEntity>
            </cac:AgentParty>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- BG-7: BUYER (Accounting Customer Party) - General Contractor -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <!-- BT-49: Buyer electronic address -->
            <cbc:EndpointID schemeID="0009">33344455500022</cbc:EndpointID>

            <!-- BT-46: Buyer identifier (SIRET) -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="0009">33344455500022</cbc:ID>
            </cac:PartyIdentification>

            <!-- BT-45: Buyer trading name -->
            <cac:PartyName>
                <cbc:Name>Groupe Construction IdF</cbc:Name>
            </cac:PartyName>

            <!-- BG-8: Buyer postal address -->
            <cac:PostalAddress>
                <!-- BT-50: Buyer address line 1 -->
                <cbc:StreetName>120 Boulevard Haussmann</cbc:StreetName>
                <!-- BT-52: Buyer city -->
                <cbc:CityName>Paris</cbc:CityName>
                <!-- BT-53: Buyer post code -->
                <cbc:PostalZone>75008</cbc:PostalZone>
                <!-- BT-55: Buyer country code -->
                <cac:Country>
                    <cbc:IdentificationCode>FR</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>

            <!-- BT-48: Buyer VAT identifier -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>FR33333444555</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>

            <!-- BT-44: Buyer legal name -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Groupe Construction Île-de-France SA</cbc:RegistrationName>
                <!-- BT-47: Buyer legal registration identifier (SIREN) -->
                <cbc:CompanyID schemeID="0002">333444555</cbc:CompanyID>
            </cac:PartyLegalEntity>

            <!-- BG-9: Buyer contact -->
            <cac:Contact>
                <cbc:Name>Marie Lambert - Responsable Travaux</cbc:Name>
                <cbc:Telephone>+33 1 53 00 22 33</cbc:Telephone>
                <cbc:ElectronicMail>m.lambert@gcif.fr</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- BG-17: Credit transfer (Payment means) -->
    <cac:PaymentMeans>
        <!-- BT-81: Payment means type code (30 = Credit transfer) -->
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode>

        <!-- BT-83: Payment reference -->
        <cbc:PaymentID>BSP-2026-COTR-0312</cbc:PaymentID>

        <!-- BG-19: Credit transfer - SELLER's IBAN -->
        <cac:PayeeFinancialAccount>
            <!-- BT-84: Payment account identifier (SELLER's IBAN) -->
            <cbc:ID>FR7644455566600011223344556677</cbc:ID>
            <!-- BT-85: Payment account name -->
            <cbc:Name>Bâtiment Solutions Provence SAS</cbc:Name>
            <cac:FinancialInstitutionBranch>
                <!-- BT-86: Payment service provider identifier (BIC) -->
                <cbc:ID>CMCIFRPPXXX</cbc:ID>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <!-- BG-20: Payment terms -->
    <cac:PaymentTerms>
        <!-- BT-20: Payment terms (free text) -->
        <cbc:Note>Paiement à 30 jours par virement bancaire. En cas de retard, pénalités au taux de 3 fois le taux d'intérêt légal en vigueur, plus indemnité forfaitaire de recouvrement de 40 EUR (articles L. 441-6 et D. 441-5 du Code de commerce). Facture de co-traitance émise via PlateformeFacture Pro SARL agissant en qualité d'agent du vendeur sur la plateforme PA-TR.</cbc:Note>
    </cac:PaymentTerms>

    <!-- BG-23: VAT breakdown -->
    <cac:TaxTotal>
        <!-- BT-110: Invoice total VAT amount -->
        <cbc:TaxAmount currencyID="EUR">5000.00</cbc:TaxAmount>

        <!-- BG-23: VAT category taxable amount and VAT -->
        <cac:TaxSubtotal>
            <!-- BT-116: VAT category taxable amount -->
            <cbc:TaxableAmount currencyID="EUR">25000.00</cbc:TaxableAmount>
            <!-- BT-117: VAT category tax amount -->
            <cbc:TaxAmount currencyID="EUR">5000.00</cbc:TaxAmount>
            <!-- BT-118: VAT category code (S = Standard rate) -->
            <cac:TaxCategory>
                <cbc:ID>S</cbc:ID>
                <!-- BT-119: VAT rate (20% standard rate) -->
                <cbc:Percent>20.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- BG-22: Document totals -->
    <cac:LegalMonetaryTotal>
        <!-- BT-106: Sum of Invoice line net amount -->
        <cbc:LineExtensionAmount currencyID="EUR">25000.00</cbc:LineExtensionAmount>
        <!-- BT-109: Invoice total amount without VAT -->
        <cbc:TaxExclusiveAmount currencyID="EUR">25000.00</cbc:TaxExclusiveAmount>
        <!-- BT-112: Invoice total amount with VAT -->
        <cbc:TaxInclusiveAmount currencyID="EUR">30000.00</cbc:TaxInclusiveAmount>
        <!-- BT-115: Amount due for payment -->
        <cbc:PayableAmount currencyID="EUR">30000.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- BG-25: INVOICE LINE 1 - Structural reinforcement works -->
    <cac:InvoiceLine>
        <!-- BT-126: Invoice line identifier -->
        <cbc:ID>1</cbc:ID>

        <!-- BT-129: Invoiced quantity (square meters) -->
        <cbc:InvoicedQuantity unitCode="MTK">200</cbc:InvoicedQuantity>

        <!-- BT-131: Invoice line net amount -->
        <cbc:LineExtensionAmount currencyID="EUR">16000.00</cbc:LineExtensionAmount>

        <!-- BG-31: Item information -->
        <cac:Item>
            <!-- BT-154: Item description -->
            <cbc:Description>Travaux de renforcement structurel - Co-traitance chantier Centre Commercial Les Terrasses de Provence: renforcement dalle béton armé niveau -1 parking souterrain, mise en conformité parasismique zone 4, traitement des armatures corrodées, injection résine époxy fissures structurelles, pose renforts fibre carbone sur poutres porteuses, conformément au CCTP lot n°3 - Gros œuvre et structure. Travaux réalisés du 1er au 28 février 2026.</cbc:Description>

            <!-- BT-153: Item name -->
            <cbc:Name>Renforcement structurel béton armé - Lot 3 co-traitance</cbc:Name>

            <!-- BG-30: Line VAT information -->
            <cac:ClassifiedTaxCategory>
                <!-- BT-151: Invoiced item VAT category code -->
                <cbc:ID>S</cbc:ID>
                <!-- BT-152: Invoiced item VAT rate (20%) -->
                <cbc:Percent>20.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>

        <!-- BG-29: Price details -->
        <cac:Price>
            <!-- BT-146: Item net price (per square meter) -->
            <cbc:PriceAmount currencyID="EUR">80.00</cbc:PriceAmount>
            <!-- BT-149: Item price base quantity -->
            <cbc:BaseQuantity unitCode="MTK">1</cbc:BaseQuantity>
        </cac:Price>
    </cac:InvoiceLine>

    <!-- BG-25: INVOICE LINE 2 - Waterproofing works -->
    <cac:InvoiceLine>
        <!-- BT-126: Invoice line identifier -->
        <cbc:ID>2</cbc:ID>

        <!-- BT-129: Invoiced quantity (square meters) -->
        <cbc:InvoicedQuantity unitCode="MTK">150</cbc:InvoicedQuantity>

        <!-- BT-131: Invoice line net amount -->
        <cbc:LineExtensionAmount currencyID="EUR">9000.00</cbc:LineExtensionAmount>

        <!-- BG-31: Item information -->
        <cac:Item>
            <!-- BT-154: Item description -->
            <cbc:Description>Travaux d'étanchéité et d'imperméabilisation - Co-traitance chantier Centre Commercial Les Terrasses de Provence: étanchéité membrane bitumineuse toiture-terrasse accessible niveau R+2, traitement joints de dilatation, pose revêtement drainant, test d'étanchéité à l'eau sous pression, conformément au CCTP lot n°3 - Gros œuvre et structure. Travaux réalisés du 10 au 28 février 2026.</cbc:Description>

            <!-- BT-153: Item name -->
            <cbc:Name>Étanchéité toiture-terrasse - Lot 3 co-traitance</cbc:Name>

            <!-- BG-30: Line VAT information -->
            <cac:ClassifiedTaxCategory>
                <!-- BT-151: Invoiced item VAT category code -->
                <cbc:ID>S</cbc:ID>
                <!-- BT-152: Invoiced item VAT rate (20%) -->
                <cbc:Percent>20.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>

        <!-- BG-29: Price details -->
        <cac:Price>
            <!-- BT-146: Item net price (per square meter) -->
            <cbc:PriceAmount currencyID="EUR">60.00</cbc:PriceAmount>
            <!-- BT-149: Item price base quantity -->
            <cbc:BaseQuantity unitCode="MTK">1</cbc:BaseQuantity>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>
