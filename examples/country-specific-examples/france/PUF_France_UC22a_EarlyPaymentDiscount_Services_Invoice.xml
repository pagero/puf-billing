            <!-- BT-149 Item price base quantity -->
            <cbc:BaseQuantity unitCode="DAY">1</cbc:BaseQuantity>
        </cac:Price>
    </cac:InvoiceLine>

    <!-- BG-25 Invoice Line 2: Security Audit -->
    <cac:InvoiceLine>
        <!-- BT-126 Invoice line identifier -->
        <cbc:ID>2</cbc:ID>
        <!-- BT-129 Invoiced quantity (days of consulting) -->
        <cbc:InvoicedQuantity unitCode="DAY">4</cbc:InvoicedQuantity>
        <!-- BT-131 Invoice line net amount -->
        <cbc:LineExtensionAmount currencyID="EUR">3600.00</cbc:LineExtensionAmount>
        <!-- BT-132 Referenced purchase order line reference -->
        <cac:OrderLineReference>
            <cbc:LineID>2</cbc:LineID>
        </cac:OrderLineReference>
        <!-- BG-31 Item Information -->
        <cac:Item>
            <!-- BT-154 Item description -->
            <cbc:Description>Audit de sécurité informatique - Tests d'intrusion et rapport de conformité</cbc:Description>
            <!-- BT-153 Item name -->
            <cbc:Name>Audit sécurité informatique</cbc:Name>
            <!-- BG-30 Line VAT Information -->
            <cac:ClassifiedTaxCategory>
                <!-- BT-151 Invoiced item VAT category code -->
                <cbc:ID>S</cbc:ID>
                <!-- BT-152 Invoiced item VAT rate -->
                <cbc:Percent>20.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <!-- BG-29 Price Details -->
        <cac:Price>
            <!-- BT-146 Item net price (daily rate) -->
            <cbc:PriceAmount currencyID="EUR">900.00</cbc:PriceAmount>
            <!-- BT-149 Item price base quantity -->
            <cbc:BaseQuantity unitCode="DAY">1</cbc:BaseQuantity>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>