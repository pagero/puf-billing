    <cbc:Note>#ABL#RCS Paris B 567 890 123</cbc:Note>
    <cbc:Note>#AAI#APE 9001Z - Arts du spectacle vivant</cbc:Note>
    <cbc:Note>#PMD#En cas de retard de paiement, application des pénalités à un taux égal au taux d'intérêt appliqué par la BCE majoré de 10 points de pourcentage</cbc:Note>
    <cbc:Note>#PMT#Indemnité forfaitaire pour frais de recouvrement en cas de retard de paiement : 40 EUR</cbc:Note>
    <cbc:Note>#BAR#B2B</cbc:Note>
    <!-- #AAB#: Early payment discount mention (mandatory) -->
    <cbc:Note>#AAB#Pas d'escompte accordé</cbc:Note>

    <!-- BT-5 Invoice Document Currency -->
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>

    <!-- BT-10 Buyer Reference -->
    <cbc:BuyerReference>BUYER-REF-2026-025A</cbc:BuyerReference>

    <!-- BT-13 Purchase Order Reference -->
    <cac:OrderReference>
        <cbc:ID>PO-2026-FR-025</cbc:ID>
        <cbc:IssueDate>2026-03-01</cbc:IssueDate>
    </cac:OrderReference>

    <!-- BG-4 Seller Information (BUU ISSUER = venue operator) -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <!-- BT-29 SIRET identifier -->
            <!-- BT-34 Seller electronic address (mandatory for EXTENDED-CTC-FR) -->
            <cbc:EndpointID schemeID="0009">56789012300018</cbc:EndpointID>
            <cac:PartyIdentification>
                <cbc:ID schemeID="0009">56789012300018</cbc:ID>
            </cac:PartyIdentification>
            <!-- BT-28 Seller Trading Name -->
            <cac:PartyName>
                <cbc:Name>Salle Olympia Productions</cbc:Name>
            </cac:PartyName>
            <!-- BG-5 Seller Address -->
            <cac:PostalAddress>
                <cbc:StreetName>28 Boulevard des Capucines</cbc:StreetName>
                <cbc:CityName>Paris</cbc:CityName>
                <cbc:PostalZone>75009</cbc:PostalZone>
                <cac:Country>
                    <cbc:IdentificationCode>FR</cbc:IdentificationCode>
                    <cbc:Name>France</cbc:Name>
                </cac:Country>
            </cac:PostalAddress>
            <!-- BT-31 Seller VAT identifier -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>FR78567890123</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <!-- BT-27 Seller legal registration -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Salle Olympia Productions SAS</cbc:RegistrationName>
                <cbc:CompanyID schemeID="0002">567890123</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Service Billetterie Entreprises</cbc:Name>
                <cbc:Telephone>+33 1 47 42 25 49</cbc:Telephone>
                <cbc:ElectronicMail>entreprises@olympia-productions.fr</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- BG-7 Buyer Information (B2B buyer purchasing vouchers) -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <!-- BT-49 Buyer electronic address (mandatory for EXTENDED-CTC-FR) -->
            <cbc:EndpointID schemeID="0009">12345678900034</cbc:EndpointID>
            <!-- BT-46 Buyer identifier -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="0009">12345678900034</cbc:ID>
            </cac:PartyIdentification>
            <!-- BT-45 Buyer Trading Name -->
            <cac:PartyName>
                <cbc:Name>Entreprise Client France</cbc:Name>
            </cac:PartyName>
            <!-- BG-8 Buyer Address -->
            <cac:PostalAddress>
                <cbc:StreetName>45 Avenue de la Liberté</cbc:StreetName>
                <cbc:CityName>Paris</cbc:CityName>
                <cbc:PostalZone>75008</cbc:PostalZone>
                <cac:Country>
                    <cbc:IdentificationCode>FR</cbc:IdentificationCode>
                    <cbc:Name>France</cbc:Name>
                </cac:Country>
            </cac:PostalAddress>
            <!-- BT-48 Buyer VAT identifier -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>FR34123456789</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <!-- BT-44 Buyer legal registration -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Entreprise Client France SA</cbc:RegistrationName>
                <cbc:CompanyID schemeID="0002">123456789</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Service Comité d'Entreprise</cbc:Name>
                <cbc:Telephone>+33 1 45 00 00 00</cbc:Telephone>
                <cbc:ElectronicMail>ce@client.fr</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- BG-19 Payment Instructions -->
    <cac:PaymentMeans>
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode>
        <cac:PayeeFinancialAccount>
            <cbc:ID>FR7630004000031234567890256</cbc:ID>
            <cbc:Name>Salle Olympia Productions SAS</cbc:Name>
            <cac:FinancialInstitutionBranch>
                <cbc:ID>BNPAFRPPXXX</cbc:ID>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <!-- BG-20 Payment Terms -->
    <cac:PaymentTerms>
        <cbc:Note>Paiement à 30 jours date de facture</cbc:Note>
    </cac:PaymentTerms>

    <!-- BG-23 VAT Breakdown -->
    <cac:TaxTotal>
        <!-- BT-110 Invoice total VAT amount -->
        <cbc:TaxAmount currencyID="EUR">500.00</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <!-- BT-116 VAT category taxable amount -->
            <cbc:TaxableAmount currencyID="EUR">2500.00</cbc:TaxableAmount>
            <!-- BT-117 VAT category tax amount -->
            <cbc:TaxAmount currencyID="EUR">500.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <!-- BT-118 VAT category code - S: Standard rate -->
                <cbc:ID>S</cbc:ID>
                <!-- BT-119 VAT rate -->
                <cbc:Percent>20.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- BG-22 Document Totals -->
    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="EUR">2500.00</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="EUR">2500.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="EUR">3000.00</cbc:TaxInclusiveAmount>
        <cbc:PayableAmount currencyID="EUR">3000.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- BG-25 Invoice Line: Single-purpose vouchers (BUU) -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <!-- BT-129 Invoiced quantity (50 vouchers) -->
        <cbc:InvoicedQuantity unitCode="C62">50</cbc:InvoicedQuantity>
        <!-- BT-131 Invoice line net amount -->
        <cbc:LineExtensionAmount currencyID="EUR">2500.00</cbc:LineExtensionAmount>
        <cac:OrderLineReference>
            <cbc:LineID>1</cbc:LineID>
        </cac:OrderLineReference>
        <!-- BG-31 Item Information -->
        <cac:Item>
            <!-- BT-154 Item description -->
            <cbc:Description>Bon à usage unique (BUU) - Accès concert catégorie Orchestre, Salle Olympia Paris. Valable pour tout spectacle de la saison 2026-2027. Place de fourniture et TVA déterminés à l'émission.</cbc:Description>
            <!-- BT-153 Item name -->
            <cbc:Name>Bon cadeau concert - Catégorie Orchestre</cbc:Name>
            <!-- BG-30 Line VAT Information -->
            <cac:ClassifiedTaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>20.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <!-- BG-29 Price Details -->
        <cac:Price>
            <!-- BT-146 Item net price (per voucher) -->
            <cbc:PriceAmount currencyID="EUR">50.00</cbc:PriceAmount>
            <cbc:BaseQuantity unitCode="C62">1</cbc:BaseQuantity>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>