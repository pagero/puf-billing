    <cbc:ID>FR-INV-2026-026</cbc:ID>
    <!-- BT-2 Invoice Issue Date -->
    <cbc:IssueDate>2026-03-15</cbc:IssueDate>
    <!-- BT-9 Payment Due Date (for the 95% immediate portion) -->
    <cbc:DueDate>2026-04-14</cbc:DueDate>
    <!-- BT-3 Invoice Type Code - 380: Commercial invoice -->
    <!-- @name = S1: Services invoice (construction/renovation services) -->
    <cbc:InvoiceTypeCode name="S1">380</cbc:InvoiceTypeCode>

    <!-- BT-21/BT-22: Invoice notes with French text codes (mandatory for France) -->
    <cbc:Note>#REG#SARL au capital de 200000.00 EUR</cbc:Note>
    <cbc:Note>#ABL#RCS Marseille B 234 567 890</cbc:Note>
    <cbc:Note>#AAI#APE 4120A - Construction de bâtiments résidentiels</cbc:Note>
    <cbc:Note>#PMD#En cas de retard de paiement, application des pénalités à un taux égal au taux d'intérêt appliqué par la BCE majoré de 10 points de pourcentage</cbc:Note>
    <cbc:Note>#PMT#Indemnité forfaitaire pour frais de recouvrement en cas de retard de paiement : 40 EUR</cbc:Note>
    <cbc:Note>#BAR#B2B</cbc:Note>
    <!-- #AAB#: Early payment discount mention (mandatory) -->
    <cbc:Note>#AAB#Pas d'escompte accordé</cbc:Note>
    <!-- #ABU#: Contractual reservation clause (UC26 specific - MANDATORY) -->
    <!-- BT-21 = ABU (UNTDID 4451 "Contract clause"), BT-22 = retention terms -->
    <!-- This is the ONLY mechanism to express the retention - no structured payment schedule supported -->
    <cbc:Note>#ABU#Retenue de garantie de 5% conformément à l'article 1er de la loi n°71-584 du 16 juillet 1971. Montant retenu : 2400.00 EUR TTC. Paiement immédiat : 45600.00 EUR TTC (95%). Le solde de 5% sera libéré à l'expiration du délai de garantie d'un an à compter de la réception des travaux, sauf mise en œuvre de la retenue.</cbc:Note>

