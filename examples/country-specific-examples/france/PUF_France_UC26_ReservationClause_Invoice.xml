        <cbc:IssueDate>2026-01-10</cbc:IssueDate>
    </cac:OrderReference>

    <!-- BG-4 Seller Information (Construction company) -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <!-- BT-29 SIRET identifier -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="0009">23456789000030</cbc:ID>
            </cac:PartyIdentification>
            <!-- BT-28 Seller Trading Name -->
            <cac:PartyName>
                <cbc:Name>BâtiRénov Méditerranée</cbc:Name>
            </cac:PartyName>
            <!-- BG-5 Seller Address -->
            <cac:PostalAddress>
                <cbc:StreetName>25 Boulevard Michelet</cbc:StreetName>
                <cbc:CityName>Marseille</cbc:CityName>
                <cbc:PostalZone>13008</cbc:PostalZone>
                <cac:Country>
                    <cbc:IdentificationCode>FR</cbc:IdentificationCode>
                    <cbc:Name>France</cbc:Name>
                </cac:Country>
            </cac:PostalAddress>
            <!-- BT-31 Seller VAT identifier -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>FR67234567890</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <!-- BT-27 Seller legal registration -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>BâtiRénov Méditerranée SARL</cbc:RegistrationName>
                <cbc:CompanyID schemeID="0002">234567890</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Service Facturation Chantiers</cbc:Name>
                <cbc:Telephone>+33 4 91 00 00 00</cbc:Telephone>
                <cbc:ElectronicMail>facturation@batirenov-med.fr</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- BG-7 Buyer Information (Property developer / client) -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <!-- BT-46 Buyer identifier -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="0009">12345678900034</cbc:ID>
            </cac:PartyIdentification>
            <!-- BT-45 Buyer Trading Name -->
            <cac:PartyName>
                <cbc:Name>Immobilière du Sud</cbc:Name>
            </cac:PartyName>
            <!-- BG-8 Buyer Address -->
            <cac:PostalAddress>
                <cbc:StreetName>10 Cours Julien</cbc:StreetName>
                <cbc:CityName>Marseille</cbc:CityName>
                <cbc:PostalZone>13006</cbc:PostalZone>
                <cac:Country>
                    <cbc:IdentificationCode>FR</cbc:IdentificationCode>
                    <cbc:Name>France</cbc:Name>
                </cac:Country>
            </cac:PostalAddress>
            <!-- BT-48 Buyer VAT identifier -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>FR34123456789</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <!-- BT-44 Buyer legal registration -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Immobilière du Sud SA</cbc:RegistrationName>
                <cbc:CompanyID schemeID="0002">123456789</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Direction des Travaux</cbc:Name>
                <cbc:Telephone>+33 4 91 50 00 00</cbc:Telephone>
                <cbc:ElectronicMail>travaux@immobiliere-sud.fr</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- BG-19 Payment Instructions -->
    <cac:PaymentMeans>
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode>
        <cac:PayeeFinancialAccount>
            <cbc:ID>FR7610096000201234567890134</cbc:ID>
            <cbc:Name>BâtiRénov Méditerranée SARL</cbc:Name>
            <cac:FinancialInstitutionBranch>
                <cbc:ID>CMCIFRPPXXX</cbc:ID>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <!-- BG-20 Payment Terms -->
    <cac:PaymentTerms>
        <!-- BT-20 Payment terms describing the split payment arrangement -->
        <cbc:Note>Paiement à 30 jours date de facture pour 95% du montant TTC (45600.00 EUR). Retenue de garantie de 5% (2400.00 EUR) libérable un an après réception des travaux.</cbc:Note>
    </cac:PaymentTerms>

    <!-- BG-23 VAT Breakdown -->
    <cac:TaxTotal>
        <!-- BT-110 Invoice total VAT amount (on FULL amount) -->
        <cbc:TaxAmount currencyID="EUR">8000.00</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="EUR">40000.00</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="EUR">8000.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>20.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- BG-22 Document Totals -->
    <!-- IMPORTANT: Invoice is for the FULL amount (100%) -->
    <!-- BT-115 = full amount - retention is a PAYMENT TIMING arrangement, not a deduction -->
    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="EUR">40000.00</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="EUR">40000.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="EUR">48000.00</cbc:TaxInclusiveAmount>
        <!-- BT-115: Full amount due - NOT the 95% immediate portion -->
        <cbc:PayableAmount currencyID="EUR">48000.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- BG-25 Invoice Line 1: Structural renovation -->
    <cac:InvoiceLine>
