    <!-- 
        Values in this file are example values only.
        PUF example file of basic invoice to create a FA XML version 3 invoice. Corresponding invoice type in FA (3): KOR_ZAL.
        In applicable cases the corresponding FA XML element is mentioned in parenthesis. 
        
        This example is based on KSeF official example file no. 13 (not covering additional buyer)
    -->
    <ext:UBLExtensions>
        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:RestrictedInformation</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <!-- Order value (WartoscZamowienia) - For KOR_ZAL this value indicates value after correction -->
                    <puf:RestrictedInformation>
                        <puf:Key>WartoscZamowienia</puf:Key>
                        <puf:Value>337635.00</puf:Value>
                    </puf:RestrictedInformation>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>

        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:RestrictedInformation</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <!-- Place of issue (P1_M) -->
                    <puf:RestrictedInformation>
                        <puf:Key>placeOfIssue</puf:Key>
                        <puf:Value>Warszawa</puf:Value>
                    </puf:RestrictedInformation>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>

        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:RestrictedInformation</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <!-- Total amount before correction (P_15ZK) -->
                    <puf:RestrictedInformation>
                        <puf:Key>P_15ZK</puf:Key>
                        <puf:Value>30000</puf:Value>
                    </puf:RestrictedInformation>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>

    </ext:UBLExtensions>
    <cbc:CustomizationID>urn:pagero.com:puf:billing:2.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:pagero.com:puf:billing:1.0</cbc:ProfileID>
    <!-- Invoice Number (P_2) -->
    <cbc:ID>INV123456</cbc:ID>
    <!-- Invoice Issue Date (P_1) -->
    <cbc:IssueDate>2026-03-17</cbc:IssueDate>
    <!-- Invoice Type Code (RodzajFaktury): KOR_ZAL - Correction of Advance invoice (384 as InvoiceTypeCode, KOR_ZAL as @name) -->
    <cbc:InvoiceTypeCode name="KOR_ZAL">384</cbc:InvoiceTypeCode>

    <!-- Invoice Document Currency (KodWaluty)-->
    <cbc:DocumentCurrencyCode>PLN</cbc:DocumentCurrencyCode>

    <cac:BillingReference>
        <cac:InvoiceDocumentReference>
            <ext:UBLExtensions>
                <ext:UBLExtension>
                    <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:BillingReferenceExtension</ext:ExtensionURI>
                    <ext:ExtensionContent>
                        <puf:PageroExtension>
                            <puf:BillingReferenceExtension>
                                <!-- Reference to the KSeF reference number of the referenced invoice (DaneFaKorygowanej/NrKSeFFaKorygowanej) -->
                                <puf:ClearanceID>9999999999-20230908-8BEF280C8D35-4D</puf:ClearanceID>
                                <puf:RestrictedInformation>
                                    <!-- Type of correction (TypKorekty)-->
                                    <puf:Key>correctionType</puf:Key>
                                    <puf:Value>3</puf:Value>
                                </puf:RestrictedInformation>
                                <!-- Reason for correction (PrzyczynaKorekty) -->
                                <cbc:Note>korekta wartości zamówienia o -10%</cbc:Note>
                            </puf:BillingReferenceExtension>
                        </puf:PageroExtension>
                    </ext:ExtensionContent>
                </ext:UBLExtension>
            </ext:UBLExtensions>
            <!-- Billing reference ID. The Invoice number of the original invoice that the correction is related to (DaneFaKorygowanej/NrFaKorygowanej) -->
            <cbc:ID>FZ2026/02/150</cbc:ID>
            <!-- Billing reference Issue Date. The Issue date of the original invoice that the correction is related to (DaneFaKorygowanej/DataWystFaKorygowanej) -->
            <cbc:IssueDate>2026-02-15</cbc:IssueDate>
        </cac:InvoiceDocumentReference>
    </cac:BillingReference>

