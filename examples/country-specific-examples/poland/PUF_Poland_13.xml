        <!-- Line net amount. Currency in attribute currencyID (P_11NettoZ) -->
        <cbc:LineExtensionAmount currencyID="PLN">341666.67</cbc:LineExtensionAmount>
        <cac:TaxTotal>

            <!--Line tax amount (P_11VatZ)-->
            <cbc:TaxAmount currencyID="PLN">27333.33</cbc:TaxAmount>
        </cac:TaxTotal>
        <cac:Item>
            <!-- Article/Item Description (P_7Z)-->
            <cbc:Name>mieszkanie 50m^2</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <!-- Invoiced item VAT category code.-->
                <cbc:ID>S</cbc:ID>
                <!-- Invoiced item VAT rate (P_12Z)-->
                <cbc:Percent>8</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
