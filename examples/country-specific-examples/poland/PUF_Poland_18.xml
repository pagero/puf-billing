    <!-- Invoice Number (P_2) -->
    <cbc:ID>INV123456</cbc:ID>
    <!-- Invoice Issue Date (P_1) -->
    <cbc:IssueDate>2026-08-17</cbc:IssueDate>

    <!-- Invoice Type Code (RodzajFaktury): KOR_ROZ - Correction of Settlement invoice (384 as InvoiceTypeCode, KOR_ROZ as @name) -->
    <cbc:InvoiceTypeCode name="KOR_ROZ">384</cbc:InvoiceTypeCode>

    <!-- Invoice Document Currency (KodWaluty)-->
    <cbc:DocumentCurrencyCode>PLN</cbc:DocumentCurrencyCode>

