<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<Invoice xmlns:cac="urn:pagero:CommonAggregateComponents:1.0" xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2" xmlns:puf="urn:pagero:ExtensionComponent:1.0" xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2" xmlns="urn:pagero:PageroUniversalFormat:Invoice:1.0">
    <cbc:CustomizationID>urn:pagero.com:puf:billing:2.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:pagero.com:puf:billing:1.0</cbc:ProfileID>
    <!-- BT-1 Invoice number -->
    <cbc:ID>INV-AE-2026-00001</cbc:ID>
    <!-- BT-2 Issue date -->
    <cbc:IssueDate>2026-04-15</cbc:IssueDate>
    <cbc:DueDate>2026-05-15</cbc:DueDate>
    <!-- BT-3 InvoiceTypeCode 380 (Tax invoice).
         @name carries BTAE-02 invoice transaction type code (8 chars, all 0 = standard tax invoice) -->
    <cbc:InvoiceTypeCode name="00000000">380</cbc:InvoiceTypeCode>
    <!-- BT-5 Document currency -->
    <cbc:DocumentCurrencyCode>AED</cbc:DocumentCurrencyCode>
    <cac:AccountingSupplierParty>
        <cac:Party>
            <!-- BT-34 Seller electronic address. UAE TRN-as-routing-id uses Peppol scheme 0235 -->
            <cbc:EndpointID schemeID="0235">100000000000003</cbc:EndpointID>
            <cac:PartyIdentification>
                <!-- BTAE-12 Seller legal registration authority (issuer of the trade license) -->
                <cbc:ID schemeID="AE:LRA">Department of Economic Development - Dubai</cbc:ID>
            </cac:PartyIdentification>
            <cac:PostalAddress>
                <!-- BT-35 Seller street -->
                <cbc:StreetName>Sheikh Zayed Road, Office 1201</cbc:StreetName>
                <!-- BT-37 Seller city -->
                <cbc:CityName>Dubai</cbc:CityName>
                <!-- BT-39 Seller country subdivision (Emirate code: AUH/DXB/SHJ/UAQ/FUJ/AJM/RAK) -->
                <cbc:CountrySubentity>DXB</cbc:CountrySubentity>
                <cac:Country>
                    <!-- BT-40 Seller country -->
                    <cbc:IdentificationCode>AE</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <!-- BT-31 Seller VAT identifier (UAE TRN: 15 chars, starts with 1, ends in 03) -->
                <cbc:CompanyID>100000000000003</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <!-- BT-27 Seller name -->
                <cbc:RegistrationName>Acme Trading LLC</cbc:RegistrationName>
                <!-- BT-30 Seller legal registration identifier.
                     BTAE-15 registration type carried in @schemeID (AE:TL/AE:EID/AE:PASSPORT/AE:CD).
                     Supplementary BTAE-12 (issuing authority) and BTAE-18 (passport country) are
                     separate cac:PartyIdentification entries with schemeID AE:LRA / AE:PASSPORT_COUNTRY. -->
                <cbc:CompanyID schemeID="AE:TL">CN-1234567</cbc:CompanyID>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingSupplierParty>
    <cac:AccountingCustomerParty>
        <cac:Party>
            <!-- BT-49 Buyer electronic address -->
            <cbc:EndpointID schemeID="0235">100000000001003</cbc:EndpointID>
            <cac:PartyIdentification>
                <!-- BTAE-11 Buyer legal registration authority -->
                <cbc:ID schemeID="AE:LRA">Abu Dhabi Department of Economic Development</cbc:ID>
            </cac:PartyIdentification>
            <cac:PostalAddress>
                <!-- BT-50 Buyer street -->
                <cbc:StreetName>Khalifa Street, Tower 5</cbc:StreetName>
                <!-- BT-52 Buyer city -->
                <cbc:CityName>Abu Dhabi</cbc:CityName>
                <!-- BT-54 Buyer country subdivision -->
                <cbc:CountrySubentity>AUH</cbc:CountrySubentity>
                <cac:Country>
                    <!-- BT-55 Buyer country -->
                    <cbc:IdentificationCode>AE</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <!-- BT-48 Buyer VAT identifier -->
                <cbc:CompanyID>100000000001003</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <!-- BT-44 Buyer name -->
                <cbc:RegistrationName>Burj Holdings PJSC</cbc:RegistrationName>
                <!-- BT-47 / BTAE-16 Buyer legal registration identifier -->
                <cbc:CompanyID schemeID="AE:TL">CN-1001003</cbc:CompanyID>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>
    <cac:PaymentMeans>
        <!-- BT-81 Payment means type code: 30 = Credit transfer -->
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode>
        <cac:PayeeFinancialAccount>
            <!-- BT-84 Payment account identifier (IBAN) -->
            <cbc:ID>AE070331234567890123456</cbc:ID>
            <cac:FinancialInstitutionBranch>
                <!-- BT-86 BIC -->
                <cbc:ID>EBILAEAD</cbc:ID>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>
    <cac:TaxTotal>
        <!-- BT-110 Invoice total VAT amount -->
        <cbc:TaxAmount currencyID="AED">50.00</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <!-- BT-116 Tax category taxable amount -->
            <cbc:TaxableAmount currencyID="AED">1000.00</cbc:TaxableAmount>
            <!-- BT-117 Tax category tax amount -->
            <cbc:TaxAmount currencyID="AED">50.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <!-- BT-118 Tax category code (S = Standard rated) -->
                <cbc:ID>S</cbc:ID>
                <!-- BT-119 Tax category rate (UAE standard rate is exactly 5.00) -->
                <cbc:Percent>5.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>
    <cac:LegalMonetaryTotal>
        <!-- BT-106 Sum of invoice line net amounts -->
        <cbc:LineExtensionAmount currencyID="AED">1000.00</cbc:LineExtensionAmount>
        <!-- BT-109 Invoice total amount without VAT -->
        <cbc:TaxExclusiveAmount currencyID="AED">1000.00</cbc:TaxExclusiveAmount>
        <!-- BT-112 Invoice total amount with VAT -->
        <cbc:TaxInclusiveAmount currencyID="AED">1050.00</cbc:TaxInclusiveAmount>
        <!-- BT-115 Amount due for payment -->
        <cbc:PayableAmount currencyID="AED">1050.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>
    <cac:InvoiceLine>
        <!-- BT-126 Line ID -->
        <cbc:ID>1</cbc:ID>
        <!-- BT-129 Invoiced quantity. BT-130 unit of measure in @unitCode -->
        <cbc:InvoicedQuantity unitCode="EA">10</cbc:InvoicedQuantity>
        <!-- BT-131 Line net amount -->
        <cbc:LineExtensionAmount currencyID="AED">1000.00</cbc:LineExtensionAmount>
        <!-- BTAE-08 VAT line amount in AED; BTAE-10 line amount in AED (both required per ibr-104-ae / ibr-194-ae) -->
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="AED">50.00</cbc:TaxAmount>
        </cac:TaxTotal>
        <cac:Item>
            <ext:UBLExtensions>
                <ext:UBLExtension>
                    <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:ItemExtension</ext:ExtensionURI>
                    <ext:ExtensionContent>
                        <puf:PageroExtension>
                            <puf:ItemExtension>
                                <puf:ItemType>GOODS</puf:ItemType>
                            </puf:ItemExtension>
                        </puf:PageroExtension>
                    </ext:ExtensionContent>
                </ext:UBLExtension>
            </ext:UBLExtensions>
        <cbc:Description>Industrial-grade centrifugal water pump, 5HP</cbc:Description>
            <cbc:Name>Industrial pump</cbc:Name>
            <cac:CommodityClassification>
                <cbc:ItemClassificationCode listID="HS">8413.70.10</cbc:ItemClassificationCode>
            </cac:CommodityClassification>
            <cac:ClassifiedTaxCategory>
                <!-- BT-151 Invoiced item tax category code -->
                <cbc:ID>S</cbc:ID>
                <!-- BT-152 Invoiced item tax rate (UAE standard rate 5.00) -->
                <cbc:Percent>5.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
            <!-- BT-154 Item description (mandatory in UAE per ibr-125-ae) -->
            <!-- BT-153 Item name -->
            <!-- BT-158 Item classification code with BT-158-1 scheme (UAE requires HS for goods) -->
            <!-- BTAE-13 Item type (GOODS / SERVICES / BOTH).
                 Carried via puf:ItemExtension/puf:ItemType -->
            </cac:Item>
        <cac:Price>
            <!-- BT-146 Item net price -->
            <cbc:PriceAmount currencyID="AED">100.00</cbc:PriceAmount>
            <!-- BT-149 Item price base quantity -->
            <cbc:BaseQuantity unitCode="EA">1</cbc:BaseQuantity>
            <!-- IBT-148 Item gross price (BTAE requirement: required per ibr-126-ae; 0.00 discount = gross equals net) -->
            <cac:AllowanceCharge>
                <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
                <cbc:Amount currencyID="AED">0.00</cbc:Amount>
                <cbc:BaseAmount currencyID="AED">100.00</cbc:BaseAmount>
            </cac:AllowanceCharge>
        </cac:Price>
    </cac:InvoiceLine>
</Invoice>