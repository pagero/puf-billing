            </cac:PostalAddress>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Gulf Beauty Retail W.L.L.</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>
    <!-- Mandatory delivery details for exports per ibr-152-ae; deliver-to country MUST NOT be AE -->
    <cac:Delivery>
