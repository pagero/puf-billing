<?xml version="1.0" encoding="UTF-8"?>
<!--
    PUF France Use Case 44: DROM Transaction - Guadeloupe to French Guiana (Flux 10.1)

    Business Scenario:
    - Seller in Guadeloupe (Group 1 — "France" for VAT) sells goods to buyer in
      French Guiana / Guyane (Group 2 — "Export" for VAT)
    - This is treated as international B2B (export) → e-reporting via Flux 10.1
    - NOT e-invoicing (Flux 1) because Guyane is outside the VAT territory

    Territorial Classification:
    - Group 1 ("France" for VAT): Métropole, Guadeloupe (GP), Martinique (MQ), La Réunion (RE)
    - Group 2 ("Export" for VAT): Guyane (GF), Mayotte (YT), all COM/TAAF

    Country Code Mapping (BR-FR-MAP-14):
    - GP, MQ, RE → must be mapped to FR in Flux 1 and Flux 10
    - GF, YT → remain as GF/YT in Flux 10.1 (they are Group 2 / export territory)
    - IMPORTANT: If invoice uses FR for a Guyane entity, must reverse-map to GF
      using postal code prefix 973xx

    Party Identification (BR-FR-MAP-16):
    - Group 1 DROM entities use SIREN (schemeID 0002), same as métropole
    - The seller country code GP is mapped to FR in the flux
    - The buyer country code GF stays as GF (or is reverse-mapped from FR via 973xx)

    VAT Treatment:
    - Export to Group 2 territory → VAT category G (export), VATEX-EU-G
    - 0% VAT — exempt as export

    Source: XP Z12-014 Annexe A v1.3, Section 3.2.43
-->
<Invoice xmlns="urn:pagero:PageroUniversalFormat:Invoice:1.0" xmlns:cac="urn:pagero:CommonAggregateComponents:1.0" xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:puf="urn:pagero:ExtensionComponent:1.0" xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2">

    <!-- ================================================================ -->
    <!-- Reporting-specific extensions (Flux 10.1 invoice reporting)       -->
    <!-- ================================================================ -->
    <ext:UBLExtensions>
        <!-- TT-1: Issuer assigned report id -->
        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:RestrictedInformation</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <puf:RestrictedInformation>
                        <puf:Key>issuerAssignedReportId</puf:Key>
                        <puf:Value>RPT-2026-044-001</puf:Value>
                    </puf:RestrictedInformation>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
        <!-- Entry type: INVOICE -->
        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:RestrictedInformation</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <puf:RestrictedInformation>
                        <puf:Key>entryType</puf:Key>
                        <puf:Value>INVOICE</puf:Value>
                    </puf:RestrictedInformation>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
        <!-- Transaction type: B2B -->
        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:RestrictedInformation</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <puf:RestrictedInformation>
                        <puf:Key>transactionType</puf:Key>
                        <puf:Value>B2B</puf:Value>
                    </puf:RestrictedInformation>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
        <!-- Report period -->
        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:RestrictedInformation</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <puf:RestrictedInformation>
                        <puf:Key>reportPeriodStart</puf:Key>
                        <puf:Value>2026-03-01</puf:Value>
                    </puf:RestrictedInformation>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
        <ext:UBLExtension>
            <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:RestrictedInformation</ext:ExtensionURI>
            <ext:ExtensionContent>
                <puf:PageroExtension>
                    <puf:RestrictedInformation>
                        <puf:Key>reportPeriodEnd</puf:Key>
                        <puf:Value>2026-03-31</puf:Value>
                    </puf:RestrictedInformation>
                </puf:PageroExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
    </ext:UBLExtensions>

    <!-- BT-24 Specification identifier -->
    <cbc:CustomizationID>urn:pagero.com:puf:billing:2.0</cbc:CustomizationID>
    <!-- Classification: Sales invoice reporting -->
    <cbc:ProfileID>urn:pagero.com:puf:billing:1.0</cbc:ProfileID>
    <!-- BT-1 Invoice Number -->
    <cbc:ID>GP-INV-2026-044</cbc:ID>
    <!-- BT-2 Invoice Issue Date -->
    <cbc:IssueDate>2026-03-10</cbc:IssueDate>
    <!-- BT-9 Payment Due Date -->
    <cbc:DueDate>2026-04-09</cbc:DueDate>
    <!-- BT-3 Invoice Type Code - 380: Commercial invoice -->
    <!-- @name = B1: Goods invoice -->
    <cbc:InvoiceTypeCode name="B1">380</cbc:InvoiceTypeCode>

    <!-- BT-21/BT-22: Invoice notes -->
    <cbc:Note>#REG#SARL au capital de 80000.00 EUR</cbc:Note>
    <cbc:Note>#ABL#RCS Pointe-à-Pitre B 555 666 777</cbc:Note>
    <cbc:Note>#AAI#APE 4632A - Commerce de gros de viandes de boucherie</cbc:Note>
    <cbc:Note>#PMD#En cas de retard de paiement, application des pénalités à un taux égal au taux d'intérêt appliqué par la BCE majoré de 10 points de pourcentage</cbc:Note>
    <cbc:Note>#PMT#Indemnité forfaitaire pour frais de recouvrement en cas de retard de paiement : 40 EUR</cbc:Note>
    <!-- #BAR#: B2BINT — treated as international B2B (Guadeloupe Group 1 → Guyane Group 2) -->
    <cbc:Note>#BAR#B2BINT</cbc:Note>
    <cbc:Note>#AAB#Pas d'escompte accordé</cbc:Note>

    <!-- BT-5 Document currency -->
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>

    <!-- BT-10 Buyer Reference -->
    <cbc:BuyerReference>GF-BUYER-REF-2026-044</cbc:BuyerReference>

    <!-- BG-4 Seller Information (Guadeloupe entity — Group 1 DROM) -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <!-- BT-29 SIRET identifier (Group 1 DROM uses SIREN/SIRET same as métropole) -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="0009">55566677700019</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name>Caraïbes Distribution</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>Zone Industrielle de Jarry</cbc:StreetName>
                <cbc:CityName>Baie-Mahault</cbc:CityName>
                <!-- BT-38 Postal code: 971xx = Guadeloupe -->
                <cbc:PostalZone>97122</cbc:PostalZone>
                <!-- BT-40 Country code: GP (Guadeloupe) -->
                <!-- BR-FR-MAP-14: GP will be mapped to FR in Flux 10.1 -->
                <cac:Country>
                    <cbc:IdentificationCode>GP</cbc:IdentificationCode>
                    <cbc:Name>Guadeloupe</cbc:Name>
                </cac:Country>
            </cac:PostalAddress>
            <!-- BT-31 Seller VAT identifier -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>FR89555666777</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <!-- TT-33: Seller identifier = SIREN (0002) for Group 1 DROM entities -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Caraïbes Distribution SARL</cbc:RegistrationName>
                <cbc:CompanyID schemeID="0002">555666777</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Service Commercial Export</cbc:Name>
                <cbc:Telephone>+590 590 00 00 00</cbc:Telephone>
                <cbc:ElectronicMail>export@caraibes-distribution.gp</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- BG-7 Buyer Information (French Guiana entity — Group 2) -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <!-- BT-46 Buyer identifier (SIREN — Guyane entities still have French SIREN) -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="0009">88899900000023</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name>Amazonie Frais</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>12 Avenue du Général de Gaulle</cbc:StreetName>
                <cbc:CityName>Cayenne</cbc:CityName>
                <!-- BT-53 Postal code: 973xx = Guyane (French Guiana) -->
                <!-- This postal code prefix is used for reverse mapping: -->
                <!-- If country code is FR, postal 973xx → map to GF in Flux 10.1 -->
                <cbc:PostalZone>97300</cbc:PostalZone>
                <!-- BT-55 Country code: GF (French Guiana) -->
                <!-- Guyane is Group 2 ("Export") — stays as GF in Flux 10.1 -->
                <cac:Country>
                    <cbc:IdentificationCode>GF</cbc:IdentificationCode>
                    <cbc:Name>Guyane française</cbc:Name>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <cbc:CompanyID>FR12888999000</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Amazonie Frais SARL</cbc:RegistrationName>
                <cbc:CompanyID schemeID="0002">888999000</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Service Achats</cbc:Name>
                <cbc:Telephone>+594 594 00 00 00</cbc:Telephone>
                <cbc:ElectronicMail>achats@amazonie-frais.gf</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- BG-13 Delivery Information -->
    <cac:Delivery>
        <cbc:ActualDeliveryDate>2026-03-08</cbc:ActualDeliveryDate>
        <cac:DeliveryLocation>
            <cac:Address>
                <cbc:StreetName>12 Avenue du Général de Gaulle</cbc:StreetName>
                <cbc:CityName>Cayenne</cbc:CityName>
                <cbc:PostalZone>97300</cbc:PostalZone>
                <!-- BT-80 Delivery country: GF -->
                <cac:Country>
                    <cbc:IdentificationCode>GF</cbc:IdentificationCode>
                </cac:Country>
            </cac:Address>
        </cac:DeliveryLocation>
    </cac:Delivery>

    <!-- BG-19 Payment Instructions -->
    <cac:PaymentMeans>
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode>
        <cac:PayeeFinancialAccount>
            <cbc:ID>FR7630006000011234567890189</cbc:ID>
            <cbc:Name>Caraïbes Distribution SARL</cbc:Name>
            <cac:FinancialInstitutionBranch>
                <cbc:ID>BNPAFRPPXXX</cbc:ID>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <cac:PaymentTerms>
        <cbc:Note>Paiement à 30 jours date de facture</cbc:Note>
    </cac:PaymentTerms>

    <!-- BG-23 VAT Breakdown -->
    <!-- Export to Group 2 territory: VAT category G (export), 0%, VATEX-EU-G -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="EUR">0.00</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="EUR">12000.00</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="EUR">0.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <!-- BT-118: G = Export -->
                <cbc:ID>G</cbc:ID>
                <cbc:Percent>0.00</cbc:Percent>
                <!-- BT-121 VAT exemption reason code -->
                <cbc:TaxExemptionReasonCode>VATEX-EU-G</cbc:TaxExemptionReasonCode>
                <!-- BT-120 VAT exemption reason text -->
                <cbc:TaxExemptionReason>Exonération de TVA - Livraison vers territoire hors champ TVA (Guyane française)</cbc:TaxExemptionReason>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- BG-22 Document Totals -->
    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="EUR">12000.00</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="EUR">12000.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="EUR">12000.00</cbc:TaxInclusiveAmount>
        <cbc:PayableAmount currencyID="EUR">12000.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- BG-25 Invoice Line -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="KGM">500</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="EUR">7500.00</cbc:LineExtensionAmount>
        <cac:Item>
            <cbc:Description>Filet de thon rouge frais de Guadeloupe, qualité export, conditionné sous vide</cbc:Description>
            <cbc:Name>Thon rouge frais Guadeloupe</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>G</cbc:ID>
                <cbc:Percent>0.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="EUR">15.00</cbc:PriceAmount>
            <cbc:BaseQuantity unitCode="KGM">1</cbc:BaseQuantity>
        </cac:Price>
    </cac:InvoiceLine>

    <cac:InvoiceLine>
        <cbc:ID>2</cbc:ID>
        <cbc:InvoicedQuantity unitCode="KGM">300</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="EUR">4500.00</cbc:LineExtensionAmount>
        <cac:Item>
            <cbc:Description>Crevettes royales fraîches de Guadeloupe, calibre 20/30, conditionné sous glace</cbc:Description>
            <cbc:Name>Crevettes royales Guadeloupe</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>G</cbc:ID>
                <cbc:Percent>0.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="EUR">15.00</cbc:PriceAmount>
            <cbc:BaseQuantity unitCode="KGM">1</cbc:BaseQuantity>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>